@model List<Lab4.Models.Usuario>
@{
    ViewData["Title"] = "Control de Acceso";
}

<h2>🎓 Control de Acceso - Institución Educativa</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-3">
    <a asp-action="Crear" class="btn btn-success">➕ Registrar Usuario</a>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Lista de Usuarios del Sistema</h5>
        
        @if (Model.Any())
        {
            <div class="row mb-3">
                <div class="col-md-4">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h6>Docentes</h6>
                            <h3>@Model.Count(u => u.Rol == "Docente")</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h6>Alumnos</h6>
                            <h3>@Model.Count(u => u.Rol == "Alumno")</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h6>Administrativos</h6>
                            <h3>@Model.Count(u => u.Rol == "Administrativo")</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Rol</th>
                            <th>Fecha Registro</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in Model.OrderByDescending(u => u.FechaRegistro))
                        {
                            <tr>
                                <td>@usuario.Id</td>
                                <td>@usuario.Nombre</td>
                                <td>@usuario.Email</td>
                                <td>
                                    <span class="badge bg-@(usuario.Rol == "Docente" ? "primary" : usuario.Rol == "Alumno" ? "info" : "warning")">
                                        @usuario.Rol
                                    </span>
                                </td>
                                <td>@usuario.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge bg-@(usuario.Activo ? "success" : "danger")">
                                        @(usuario.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="Editar" asp-route-id="@usuario.Id" class="btn btn-sm btn-warning">✏️ Editar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No hay usuarios registrados.</p>
        }
    </div>
</div>

<div class="mt-4 alert alert-info">
    <strong>ℹ️ Ejercicio 2:</strong> Este módulo utiliza StreamWriter/StreamReader para leer y escribir 
    el archivo JSON. Implementa control de concurrencia con SemaphoreSlim para garantizar la integridad de los datos.
</div>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">← Volver al inicio</a>
</div>
