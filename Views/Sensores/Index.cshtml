@model List<Lab4.Models.LecturaSensor>
@{
    ViewData["Title"] = "Monitoreo de Sensores";
}

<h2>🌡️ Monitoreo Ambiental - Sensores IoT</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-3 d-flex gap-2">
    <a asp-action="Registrar" class="btn btn-info">➕ Nueva Lectura</a>
    <a asp-action="Graficas" class="btn btn-success">📈 Ver Gráficas</a>
    <form asp-action="SimularLecturas" method="post" class="d-inline">
        <button type="submit" class="btn btn-warning">🔄 Simular 10 Lecturas</button>
    </form>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Últimas 50 Lecturas</h5>
        
        @if (Model.Any())
        {
            <div class="row mb-3">
                <div class="col-md-3">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h6>Total Lecturas</h6>
                            <h3>@Model.Count</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h6>Temp. Promedio</h6>
                            <h3>@Model.Average(l => l.Temperatura).ToString("F1")°C</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h6>Humedad Promedio</h6>
                            <h3>@Model.Average(l => l.Humedad).ToString("F1")%</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-light">
                        <div class="card-body text-center">
                            <h6>Sensores Activos</h6>
                            <h3>@Model.Select(l => l.SensorId).Distinct().Count()</h3>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-sm">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Sensor</th>
                            <th>Temperatura</th>
                            <th>Humedad</th>
                            <th>Ubicación</th>
                            <th>Fecha/Hora</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lectura in Model)
                        {
                            <tr>
                                <td>@lectura.Id</td>
                                <td><span class="badge bg-secondary">@lectura.SensorId</span></td>
                                <td>
                                    <span class="badge bg-@(lectura.Temperatura > 30 ? "danger" : lectura.Temperatura > 20 ? "warning" : "info")">
                                        @lectura.Temperatura.ToString("F2")°C
                                    </span>
                                </td>
                                <td>@lectura.Humedad.ToString("F2")%</td>
                                <td>@lectura.Ubicacion</td>
                                <td>@lectura.FechaLectura.ToString("dd/MM/yyyy HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No hay lecturas registradas.</p>
        }
    </div>
</div>

<div class="mt-4 alert alert-info">
    <strong>ℹ️ Ejercicio 3:</strong> Este módulo implementa serialización JSON con rotación automática de archivos. 
    Cuando un archivo supera el tamaño máximo, se crea uno nuevo automáticamente.
</div>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">← Volver al inicio</a>
</div>
